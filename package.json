{
  "name": "zustand-sagas",
  "version": "0.1.0",
  "description": "Redux-saga-style generator-based side effect management for Zustand",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zustand": ">=4"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "zustand": "^5.0.0"
  },
  "license": "MIT",
  "keywords": ["zustand", "saga", "sagas", "redux-saga", "generator", "side-effects", "middleware"]
}
